# ML-DEP environment configuration — copy to .env.local and fill in.
# NEVER commit real values. .env.local is gitignored.

# --- Supabase (Auth + Storage client) ---
# From your Supabase project: Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=
# The publishable key (sb_publishable_...). Public — it reaches the browser.
# The legacy NEXT_PUBLIC_SUPABASE_ANON_KEY still works as a fallback.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only secret key (sb_secret_...), or the legacy service_role JWT. Not
# used by the app today; kept for a future admin path. Never expose to the browser.
SUPABASE_SECRET_KEY=

# --- Database (Prisma) ---
# Supabase Postgres connection. Settings > Database > Connection pooling >
# Transaction (…pooler.supabase.com:6543/postgres?pgbouncer=true). The pooler is
# required in serverless (Vercel) — the direct db.<ref>.supabase.co host is
# IPv6-only and unreachable there.
DATABASE_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Feature flags ---
# Business capabilities ship dark and turn on with their phase. Unset means off,
# except registration, which is a kill switch and defaults on.
# Set to "true" to enable. See lib/config/features.ts.
NEXT_PUBLIC_FEATURE_TEMPLATE_MARKETPLACE=
NEXT_PUBLIC_FEATURE_INVITATION_BUILDER=
NEXT_PUBLIC_FEATURE_MEDIA_LIBRARY=
NEXT_PUBLIC_FEATURE_WEBSITE_GENERATOR=
NEXT_PUBLIC_FEATURE_PDF_GENERATION=
NEXT_PUBLIC_FEATURE_BOOKING=
NEXT_PUBLIC_FEATURE_PAYMENTS=
# Leave blank to allow sign-ups; set to "false" to close registration.
NEXT_PUBLIC_FEATURE_REGISTRATION=
