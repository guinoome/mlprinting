# Normalize line endings: LF in the repository, native in the working copy.
# Without this, Windows and the Linux CI runner disagree on every file and
# diffs fill with phantom whole-file changes.
* text=auto eol=lf

# Binary — never touch these.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary

# Generated — collapse in diffs and exclude from language stats.
pnpm-lock.yaml linguist-generated=true -diff
